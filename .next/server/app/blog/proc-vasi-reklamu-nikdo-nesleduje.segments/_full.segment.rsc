24:["$","a",null,{"href":"https://twitter.com/intent/tweet?url=https%3A%2F%2Fjajsemtomas.cz%2Fblog%2Fproc-vasi-reklamu-nikdo-nesleduje&text=Pro%C4%8D%20va%C5%A1e%20reklamy%20na%20Facebooku%20nefunguj%C3%AD%3F%20(Psychologie%20div%C3%A1ka)","target":"_blank","rel":"noopener noreferrer","className":"inline-flex items-center gap-2 px-4 py-2 bg-black hover:bg-gray-800 text-white rounded-lg transition-colors text-sm font-medium","children":[["$","svg",null,{"className":"w-4 h-4","fill":"currentColor","viewBox":"0 0 24 24","children":["$","path",null,{"d":"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"}]}],"Tweet"]}]
